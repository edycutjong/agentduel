# AgentDuel — copy to .env.local (gitignored) and fill in. NEVER commit real keys.

# Football results — the referee. football-data.org, FIFA World Cup 2026 (comp 2000).
FOOTBALL_DATA_KEY=
# Optional: consensus odds for CYAN's free strategy (the-odds-api.com).
ODDS_API_KEY=

# Arena wallet = facilitator (x402 settlement) + payout sender. Throwaway, capped.
OPS_WALLET_ADDRESS=0x95DdED219bD3d763A184eB4187056b9F238aAaA2
OPS_WALLET_PK=
# x402 payTo receiver — ADDRESS ONLY, never its key.
PAYTO_ADDRESS=0x45078eD96C2bB171009A47a57aF5C085Bf4fD0e3

# --- toggles ---
# Network for the x402 middleware: mainnet (default) | testnet.
AGENTDUEL_NETWORK=mainnet
# LineLock paid-pick API (RED's edge source). Not required live — RED degrades to a recorded fixture.
LINELOCK_URL=http://localhost:8402
# HARD funds gate. The real on-chain payout runs ONLY when this === "1" AND the wallet holds USDC.
# Left unset/0, settlement uses the labeled mock and never emits a real tx.
AGENTDUEL_ALLOW_PAYOUT=0
# API port.
PORT=8403
